{
    "name": "priotti/api",
    "description": "PHP API for Priotti v3",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.7",
        "firebase/php-jwt": "^6.10",
        "phpoffice/phpspreadsheet": "^2.1",
        "vlucas/phpdotenv": "^5.6",
        "tuupola/cors-middleware": "^1.1",
        "phpmailer/phpmailer": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "slim/slim": true
        },
        "audit": {
            "abandoned": "report",
            "block-insecure": false
        },
        "platform": {
            "php": "8.1.0"
        }
    }
}
