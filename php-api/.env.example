PORT=3001
JWT_SECRET=your_jwt_secret

DATABASE_URL="mysql://user:password@localhost:3306/database_name"

# Mail Variables (Configure according to environment)
# For local development with mailpit:
# MAIL_HOST=localhost, MAIL_PORT=1025, no credentials/encryption
# For Production:
# MAIL_HOST=mail.felipepriotti.com.ar, MAIL_PORT=465, encryption=ssl
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
# Encryption: '' (empty), 'tls', or 'ssl'
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=contacto@felipepriotti.com.ar
MAIL_FROM_NAME="Pedidos Priotti"
# Comma-separated list for multiple admin recipients
MAIL_ADMIN_TO=fpriotti@felipepriotti.com.ar,contacto@felipepriotti.com.ar
